# Copy this file to API.env (or .env) and fill in your own keys.
# NEVER commit the populated file.

# --- LLM providers ---
GROQ_API_KEY=your_groq_key_here
GEMINI_API_KEY=your_gemini_key_here

# --- Web search ---
# Tavily gives higher-quality results; DuckDuckGo is used as a free fallback.
TAVILY_API_KEY=your_tavily_key_here
SEARCH_PROVIDER=tavily   # tavily | duckduckgo

# --- Ollama (for the local Mistral model) ---
# When running outside Docker: http://localhost:11434
# When running inside docker-compose with the ollama service: http://ollama:11434
OLLAMA_BASE_URL=http://localhost:11434

# --- UI <-> API wiring (only needed in Docker) ---
API_URL=http://api:8000
